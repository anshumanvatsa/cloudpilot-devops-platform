APP_NAME=CloudPilot Backend
ENVIRONMENT=development
API_PREFIX=/api
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DATABASE_URL=postgresql+psycopg://cloudpilot:cloudpilot@postgres:5432/cloudpilot
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=http://localhost:8080,http://localhost:5173
RATE_LIMIT=100/minute
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
REFRESH_COOKIE_NAME=cloudpilot_refresh
CSRF_COOKIE_NAME=cloudpilot_csrf
CSRF_HEADER_NAME=X-CSRF-Token
